# ============================================================
# NexCV Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ─── MongoDB ──────────────────────────────────────────────────
# Local MongoDB instance (default) or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/nexcv

# ─── JWT Authentication ──────────────────────────────────────
# Generate a random secret key: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRES=30d

# ─── Gemini API (for CV Scoring) ──────────────────────────────
# Get your free API key at: https://aistudio.google.com/apikey
# The system uses Gemini 3.1 Flash Lite for CV analysis.
# If no key is provided, it falls back to the local knowledge base engine.
GEMINI_API_KEY=

# ─── Server ───────────────────────────────────────────────────
PORT=8000
