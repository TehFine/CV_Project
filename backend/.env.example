# ============================================================
# NexCV Backend Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ─── MongoDB ──────────────────────────────────────────────────
# Local MongoDB instance (default) or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/nexcv

# ─── JWT Authentication ──────────────────────────────────────
# Generate a random secret key: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRES=30d

# ─── Gemini API (for CV Scoring) ──────────────────────────────
# Get your free API key at: https://aistudio.google.com/apikey
# The system uses Gemini 3.1 Flash Lite for CV analysis.
# If no key is provided, it falls back to the local knowledge base engine.
GEMINI_API_KEY=

# ─── Email (SMTP) ─────────────────────────────────────────────
# Used for sending password reset emails.
# For Gmail: use smtp.gmail.com, port 587, and an App Password.
# For Mailtrap (dev): use sandbox.smtp.mailtrap.io, port 2525.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NexCV <noreply@nexcv.vn>

# ─── Frontend URL ─────────────────────────────────────────────
# Used to build the password reset link in emails
FRONTEND_URL=http://localhost:5173

# ─── Server ───────────────────────────────────────────────────
PORT=3000
